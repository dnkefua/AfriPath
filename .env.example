# APP_URL: The URL where the hosted web app lives (Firebase App Hosting).
APP_URL="https://afripath--afripath.europe-west4.hosted.app/"

# VITE_APP_URL / VITE_BACKEND_URL: Browser-safe URLs exposed to the Vite app.
# The app fetches the latest catalog from `${VITE_BACKEND_URL}/api/catalog.json`
# and falls back to the bundled catalog when offline.
VITE_APP_URL="https://afripath--afripath.europe-west4.hosted.app/"
VITE_BACKEND_URL="https://afripath--afripath.europe-west4.hosted.app/"

# AFRIPATH_SYNC_KEY (server) / VITE_AFRIPATH_SYNC_KEY (dev client):
# Shared secret for the admin snapshot sync endpoint. Leave the server value
# unset to disable the endpoint entirely. Never ship the VITE_ value in a
# public build - it is for local admin/dev use only.
# AFRIPATH_SYNC_KEY=""
# VITE_AFRIPATH_SYNC_KEY=""
